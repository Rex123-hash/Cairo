rules_version = '2';

// Cairo Firestore security rules.
// History is private per user: each signed-in user (incl. anonymous auth) can
// only read and write documents under their own UID. Nothing is world-readable
// and writes must carry a sane footprint value.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId}/history/{entryId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.totalMonthlyKg is number
        && request.resource.data.totalMonthlyKg >= 0
        && request.resource.data.totalMonthlyKg < 100000;

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
