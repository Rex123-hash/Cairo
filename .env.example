# ─────────────────────────────────────────────────────────────
# Cairo environment variables
# Copy this file to `.env.local` and fill in your own keys.
# The app works WITHOUT any of these (offline fallback mode);
# adding keys upgrades parsing, explanations and distances.
# ─────────────────────────────────────────────────────────────

# Google Gemini API key (https://aistudio.google.com/apikey)
# Powers natural-language parsing + friendly coaching explanations.
VITE_GEMINI_API_KEY=

# Google Maps Platform key (Distance Matrix API enabled, referrer-restricted)
# Converts "home to office" into real commute distance in km.
VITE_MAPS_API_KEY=

# Firebase config (optional — enables cross-device history via Firestore)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
